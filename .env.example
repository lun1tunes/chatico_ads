# App
ENVIRONMENT=development
DEBUG=false
PORT=8000
FRONTEND_PORT=4173
FRONTEND_URL=http://localhost:4173
PUBLIC_APP_URL=http://localhost:8000
VITE_APP_BASE_PATH=/
VITE_API_BASE_URL=http://localhost:8000/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173

# Database
POSTGRES_DB=chatico_ads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chatico_ads
META_REPORT_CACHE_TTL_SECONDS=45
META_REPORT_SNAPSHOT_TTL_SECONDS=2592000

# Auth
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_COOKIE_NAME=chatico_ads_refresh_token
# Optional. Defaults to the path segment from FRONTEND_URL (e.g. /chatico_ads on subpath deploys).
# REFRESH_COOKIE_PATH=/chatico_ads
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
FIELD_ENCRYPTION_KEY=replace_with_fernet_key_generated_by_python

# Meta OAuth / Marketing API
META_APP_ID=replace_with_meta_app_id
META_APP_SECRET=replace_with_meta_app_secret
META_GRAPH_VERSION=v24.0
META_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/meta/oauth/callback
META_OAUTH_SCOPES=ads_read
META_OAUTH_CONFIG_ID=
META_EXCHANGE_LONG_LIVED_TOKEN=true

# Google Ads API / Google Cloud Console
GOOGLE_ADS_DEVELOPER_TOKEN=replace_with_google_ads_developer_token
GOOGLE_ADS_API_VERSION=v22
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/google-ads/oauth/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/adwords
GOOGLE_OAUTH_ACCESS_TYPE=offline
GOOGLE_OAUTH_INCLUDE_GRANTED_SCOPES=true
GOOGLE_OAUTH_PROMPT=consent

# Internal AI verdict provider
INTERNAL_AI_PROVIDER=gemini
INTERNAL_GEMINI_API_KEY=replace_with_server_gemini_key
INTERNAL_ANTHROPIC_API_KEY=
INTERNAL_ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01
OPENAI_DEFAULT_MODEL=gpt-5-mini
GEMINI_DEFAULT_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
LLM_MAX_TOKENS=1200
