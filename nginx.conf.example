# Drop-in Nginx addition for the existing domain server block.
#
# Current machine state:
# - active site file: /etc/nginx/sites-available/lunitunestmb.com
# - existing app route: /chatico/
# - new Chatico Ads route: /chatico_ads/
#
# Insert this snippet inside the HTTPS `server { ... }` block,
# preferably above:
#   location = / {
#       return 301 https://$server_name/chatico;
#   }
#
# Required app settings before deploy:
#   FRONTEND_URL=https://lunitunes.com/chatico_ads
#   VITE_APP_BASE_PATH=/chatico_ads/
#   VITE_API_BASE_URL=/chatico_ads/api/v1
#   META_OAUTH_REDIRECT_URI=https://lunitunes.com/chatico_ads/api/v1/meta/oauth/callback
#   CORS_ALLOWED_ORIGINS=https://lunitunes.com
#
# If the live Nginx config still uses `server_name lunitunestmb.com`,
# update the domain and certificate paths separately when switching to
# `lunitunes.com`.

# Canonical trailing slash for the app root.
location = /chatico_ads {
    return 301 /chatico_ads/;
}

# FastAPI API under the app prefix.
# This includes auth, dashboard, AI proxy, and Meta OAuth callback:
#   /chatico_ads/api/v1/meta/oauth/callback
location /chatico_ads/api/ {
    client_max_body_size 20m;

    proxy_pass http://127.0.0.1:8000/api/;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /chatico_ads;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_cache_bypass $http_upgrade;

    proxy_connect_timeout 60s;
    proxy_send_timeout 120s;
    proxy_read_timeout 120s;
}

# Optional external health checks.
location /chatico_ads/health/ {
    proxy_pass http://127.0.0.1:8000/health/;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /chatico_ads;
}

# Vue SPA under /chatico_ads/.
# The trailing slash in proxy_pass strips the prefix before sending the
# request to the front container.
location /chatico_ads/ {
    proxy_pass http://127.0.0.1:4173/;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /chatico_ads;
}
